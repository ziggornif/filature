# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- PostgreSQL (the `db` service) ---
POSTGRES_USER=filature
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=filature

# --- App publish address ---
# Port the app is published on, and the host interface to bind it to.
# Default 0.0.0.0 exposes it on every interface — set APP_BIND to a private IP
# if the reverse-proxy host reaches this VM over a private network.
APP_PORT=8080
APP_BIND=0.0.0.0

# --- Demo auth gate (slice 08) ---
# The login gate is ALWAYS active — AUTH_PASSWORD_HASH is mandatory or the app
# refuses to boot. Username defaults to "demo".
AUTH_USERNAME=demo
# Generate the argon2 hash for your password:
#   docker compose run --rm app hash-password 'your-password'
# (or, from a checkout: cargo run -p filature -- hash-password 'your-password')
#
# IMPORTANT: docker-compose interpolates `$` in .env values, and an argon2 hash
# is full of them. Double EVERY `$` as `$$` when pasting the hash below, e.g.
#   AUTH_PASSWORD_HASH=$$argon2id$$v=19$$m=19456,t=2,p=1$$SALT$$DIGEST
# AUTH_PASSWORD_HASH=

# --- App ---
# UI default locale (fr | en).
FILATURE_DEFAULT_LOCALE=fr
# Log verbosity (tracing EnvFilter syntax). Leave unset for the built-in
# default (info,tower_http=debug,sqlx=warn). Examples: debug | warn |
# info,filature=debug,tower_http=debug
# RUST_LOG=info,tower_http=debug,sqlx=warn

# --- Machine Link (slice 22a) ---
# Key encrypting machine credentials at rest (PrusaLink API key), AES-256-GCM.
# Required as soon as a Machine Link with a credential exists — boot fails
# loudly otherwise (see docs/adr/0006-machine-credentials-encryption.md).
# Generate: openssl rand -base64 32
# FILATURE_CREDENTIALS_KEY=

# Set to 1 on demo instances: hides the Machine Link form section and the
# dashboard Farm Activity panel (no LAN reachable from a public demo).
# FILATURE_DEMO=
