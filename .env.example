# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- PostgreSQL (the `db` service) ---
POSTGRES_USER=filature
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=filature

# --- App publish address ---
# Port the app is published on, and the host interface to bind it to.
# Default 0.0.0.0 exposes it on every interface — set APP_BIND to a private IP
# if the reverse-proxy host reaches this VM over a private network.
APP_PORT=8080
APP_BIND=0.0.0.0

# --- App ---
# UI default locale (fr | en).
FILATURE_DEFAULT_LOCALE=fr
# Log verbosity (tracing EnvFilter syntax). Leave unset for the built-in
# default (info,tower_http=debug,sqlx=warn). Examples: debug | warn |
# info,filature=debug,tower_http=debug
# RUST_LOG=info,tower_http=debug,sqlx=warn
